---
import Link from './Link.astro';
import { Button } from '@/components/ui/button';
---

<footer class="sticky top-[100vh] mt-auto border-t bg-white py-6 md:py-0">
  <div
    class="text-muted-foreground mx-auto flex max-w-screen-xl flex-col px-4 text-sm md:h-16 md:flex-row md:items-center md:justify-between md:px-8"
  >
    <p>© 2025 Papua Open Source. All rights reserved.</p>
    <div class="mt-4 flex gap-4 md:mt-0">
      <Button variant="link" size="sm">
        <Link
          href="/kebijakan-privasi/"
          class="font-normal text-slate-500 hover:text-slate-700"
          activeClass="text-slate-700 hover:text-slate-900"
          >Kebijakan Privasi</Link
        >
      </Button>
      <Button variant="link" size="sm">
        <Link
          href="/syarat-ketentuan/"
          class="font-normal text-slate-500 hover:text-slate-700"
          activeClass="text-slate-700 hover:text-slate-900"
          >Syarat dan Ketentuan</Link
        >
      </Button>
    </div>
  </div>
</footer>
