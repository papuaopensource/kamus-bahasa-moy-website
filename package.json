{
  "name": "kamusbahasamoy",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "preview": "turbo preview",
    "lint": "turbo lint",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:migration": "pnpm --filter @kamus-bahasa-moy/api docker:migration",
    "docker:seed": "pnpm --filter @kamus-bahasa-moy/api docker:seed",
    "db:exec": "pnpm --filter @kamus-bahasa-moy/api db:exec",
    "docker:rm": "pnpm --filter @kamus-bahasa-moy/api docker:rm",
    "docker:init": "pnpm --filter @kamus-bahasa-moy/api docker:init",
    "docker:clean": "pnpm --filter @kamus-bahasa-moy/api docker:clean"
  },
  "devDependencies": {
    "turbo": "^2.5.3"
  },
  "packageManager": "pnpm@10.20.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "sharp"]
  }
}
